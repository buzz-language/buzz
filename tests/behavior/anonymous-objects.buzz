import "buzz:std";

fun getInfo() > obj{ name: str, age: int } {
    return .{
        name = "Joe",
        age = 36,
    };
}

test "Anonymous objects" {
    final info = getInfo();
    // Two anonymous type matches
    _: obj{ name: str, age: int } = info;

    std\assert(
        info.name == "Joe" and info.age == 36,
        message: "Could declare, instanciate and acces anonymous objects",
    );

    std\assert(
        info is obj{ name: str, age: int },
        message: "Type safety works with anonymous object",
    );
}

test "Named variable init" {
    final name = "Joe";
    final age = 42;

    final person = .{ name, age };

    std\assert(person.name == "Joe" and person.age == 42);
}

fun getPayload::<T>(data: T) > obj{ data: T } {
    return .{
        data = data,
    };
}

test "Anonymous object with generics" {
    final payload = getPayload::<int>(42);

    std\assert(
        payload.data == 42,
        message: "Could use anonymous object with generic"
    );
}

object InferredPayload {
    data: str,
    suffix: str = "!",

    fun describe() > str {
        return "{this.data}{this.suffix}";
    }
}

test "Anonymous object inferred as named object" {
    final payload: InferredPayload = .{ data = "hello" };

    std\assert(
        payload.describe() == "hello!",
        message: "Inferred anonymous object can use named object methods",
    );
}

fun callMe(o: obj{ x: int, y: int }) > void {
    std\assert(o.x == 12 and o.y == 13);
}

test "anonymous objects with different fields order" {
    callMe(.{ y = 13, x = 12 });
}

/// Option-like object used by nested anonymous object inference regression.
object NestedInferenceOption {
    /// Display name for the option.
    name: str,
    /// Alternate spellings for the option.
    aliases: [str] = [],
    /// Whether the option consumes the next command-line value.
    hasValue: bool = false,
    /// Parsed option value.
    value: str?,
}

/// Argument-like object used by nested anonymous object inference regression.
object NestedInferenceArgument {
    /// Display name for the argument.
    name: str,
    /// Maximum number of values consumed by the argument.
    max: int? = 1,
    /// Parsed argument values.
    value: [str]?,
}

/// Recursive command-like object used by nested anonymous object inference regression.
object NestedInferenceCommand {
    /// Options accepted by the command.
    options: {str: mut NestedInferenceOption} = {},
    /// Positional arguments accepted by the command.
    arguments: {str: mut NestedInferenceArgument} = {},
    /// Nested subcommands accepted by the command.
    commands: {str: mut NestedInferenceCommand} = {},
}

test "nested anonymous object inference through maps and lists" {
    final command = mut NestedInferenceCommand{
        options = {
            "help": mut .{
                name = "help",
                aliases = [ "h" ],
            },
        },
        commands = {
            "add": mut .{
                options = {
                    "file": mut .{
                        name = "file",
                        aliases = [ "f" ],
                    },
                },
                arguments = {
                    "entry": mut .{
                        name = "entry",
                        max = null,
                    },
                },
            },
            "modify": mut .{
                arguments = {
                    "id": mut .{
                        name = "id",
                        max = 1,
                    },
                    "entry": mut .{
                        name = "entry",
                        max = null,
                    },
                },
            },
        },
    };

    std\assert(command.commands["modify"]!.arguments["id"]!.max == 1);
    std\assert(command.commands["modify"]!.arguments["entry"]!.max == null);
}

/// placeholders in anonymous object fields works
object A {
    board: mut [int],

    fun free() > void {
        foreach (x, y in this.board) {
            var board: mut [obj{ x: int }] = mut [];

            board.append(.{ x });
        }
    }
}
