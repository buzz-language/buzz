import "buzz:std";

fun check(peeked: int) > bool {
    final local = peeked;

    if (('a'..'z').contains(local) or ('A'..'Z').contains(local)
        or ('0'..'9').contains(local) or local == '_' or local == '-') {
        return true;
    } else if (local == '"') {
        return false;
    }

    return local == peeked;
}

test "Range expression does not move locals into condition scope" {
    std\assert(
        check('a'),
        message: "Local remains visible after range expression in if condition"
    );
}
