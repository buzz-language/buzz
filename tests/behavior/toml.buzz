import "buzz:toml";
import "buzz:std";
import "buzz:serialize" as _;

fun assertInvalidToml(source: str, message: str) > void {
    var invalid = false;

    try {
        if (toml\decode(source) == null) {
            invalid = false;
        }
    } catch (_: toml\Error) {
        invalid = true;
    }

    std\assert(invalid, message: message);
}

test "Simple key/value" {
    final toml = `
        hello = "world"
        number = 42
        some.deep.key = "well done"
    `;

    final data = Boxed.init(
        toml\decode(toml),
    );

    std\assert(data.q([ "hello" ]).string() == "world");
    std\assert(data.q([ "number" ]).integer() == 42);
    std\assert(data.q([ "some", "deep", "key" ]).string() == "well done");
}

test "Section" {
    final toml = `
        hello = "world"
        [section]
        number = 42
        some.deep.key = "well done"
    `;

    final data = Boxed.init(
        toml\decode(toml),
    );

    std\assert(data.q([ "hello" ]).string() == "world");
    std\assert(data.q([ "section", "number" ]).integer() == 42);
    std\assert(data.q([ "section", "some", "deep", "key" ]).string()
        == "well done");
}

test "Several sections" {
    final toml = `
        hello = "world"
        [section]
        number = 42
        [another]
        some.deep.key = "well done"
    `;

    final data = Boxed.init(
        toml\decode(toml),
    );

    std\assert(data.q([ "hello" ]).string() == "world");
    std\assert(data.q([ "section", "number" ]).integer() == 42);
    std\assert(data.q([ "another", "some", "deep", "key" ]).string()
        == "well done");
}

test "Array of sections" {
    final toml = `
        hello = "world"
        [[section]]
        number = 42
        [[section]]
        number = 43
    `;

    final data = Boxed.init(
        toml\decode(toml),
    );

    std\assert(data.q([ "hello" ]).string() == "world");
    std\assert(data.q([ "section", 0, "number" ]).integer() == 42);
    std\assert(data.q([ "section", 1, "number" ]).integer() == 43);
}

test "Nested array of sections" {
    final toml = `
        [[fruit]]
        name = "apple"

        [[fruit.variety]]
        name = "red delicious"

        [[fruit.variety]]
        name = "granny smith"
    `;

    final data = Boxed.init(
        toml\decode(toml),
    );

    std\assert(data.q([ "fruit", 0, "name" ]).string() == "apple");
    std\assert(
        data.q([ "fruit", 0, "variety", 0, "name" ]).string() == "red delicious"
    );
    std\assert(
        data.q([ "fruit", 0, "variety", 1, "name" ]).string() == "granny smith"
    );
}

test "Comments and blank lines" {
    final toml = `

        # root comment
        hello = "world" # inline comment

        [section] # table comment
        number = 42
    `;

    final data = Boxed.init(
        toml\decode(toml),
    );

    std\assert(data.q([ "hello" ]).string() == "world");
    std\assert(data.q([ "section", "number" ]).integer() == 42);
}

test "Multiline arrays and inline tables" {
    final toml = `
        numbers = [
            1,
            # array comment
            2,
        ]

        point = \{ x = 1, y = "two" }
    `;

    final data = Boxed.init(
        toml\decode(toml),
    );

    std\assert(data.q([ "numbers", 0 ]).integer() == 1);
    std\assert(data.q([ "numbers", 1 ]).integer() == 2);
    std\assert(data.q([ "point", "x" ]).integer() == 1);
    std\assert(data.q([ "point", "y" ]).string() == "two");
}

test "Inline table newlines and trailing commas are rejected" {
    assertInvalidToml(
        `
            point = \{
                x = 1
            }
        `,
        message: "inline table cannot contain newlines",
    );

    assertInvalidToml(
        `
            point = \{ x = 1, }
        `,
        message: "inline table cannot contain trailing comma",
    );
}

test "Tables under latest array table element" {
    final toml = `
        [[fruit]]
        name = "apple"

        [fruit.physical]
        color = "red"

        [[fruit]]
        name = "banana"

        [fruit.physical]
        color = "yellow"
    `;

    final data = Boxed.init(
        toml\decode(toml),
    );

    std\assert(data.q([ "fruit", 0, "name" ]).string() == "apple");
    std\assert(data.q([ "fruit", 0, "physical", "color" ]).string() == "red");
    std\assert(data.q([ "fruit", 1, "name" ]).string() == "banana");
    std\assert(data.q([ "fruit", 1, "physical", "color" ]).string() == "yellow");
}

test "Duplicate and conflicting definitions are rejected" {
    assertInvalidToml(
        `
            key = 1
            key = 2
        `,
        message: "duplicate key",
    );

    assertInvalidToml(
        `
            [table]
            value = 1
            [table]
            other = 2
        `,
        message: "duplicate explicit table",
    );

    assertInvalidToml(
        `
            dotted.value = 1
            dotted = 2
        `,
        message: "value cannot replace table",
    );

    assertInvalidToml(
        `
            inline = \{ value = 1 }
            inline.other = 2
        `,
        message: "inline table is sealed",
    );

    assertInvalidToml(
        `
            [[array]]
            value = 1
            [array]
            other = 2
        `,
        message: "array table cannot become regular table",
    );
}

test "invalid/table/with-pound" {
    assertInvalidToml(`
            [key#group]
            answer = 42
        `, message: "invalid table with-pound");
}
