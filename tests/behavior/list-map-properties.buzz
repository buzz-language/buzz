import "std";

object Hey {
    ages: [int],
    names: {int: str},
}

object MutableHey {
    ages: mut [int],
    names: mut {int: str},
}

test "List and Map as Object properties" {
    final hey = Hey{
        ages = [ 1, 2, 3 ],
        names = { 1: "hello" },
    };

    std\assert(hey.ages[0] == 1, message: "list access");
    std\assert(hey.names[1] == "hello", message: "map access");
}

test "Mutable List and Map as Object properties" {
    final hey = MutableHey{
        ages = mut [],
        names = mut {},
    };

    std\assert(hey.ages.len() == 0, message: "mutable list access");
    std\assert(hey.names.size() == 0, message: "mutable map access");
}
