import "buzz:std";

/// Return enum value with an anonymous enum case default declared before the enum.
fun getForwardAnonymousDefaultValue(case: ForwardDefaultEnum = .one) > int {
    return case.value;
}

/// Object used to verify forward anonymous enum default values in methods.
object ForwardNaturalDefaults {
    /// Return enum value with an anonymous enum case default declared before the enum.
    static fun getValue(case: ForwardDefaultEnum = .two) > int {
        return case.value;
    }
}

/// Enum declared after functions that use it as a default parameter type.
enum ForwardDefaultEnum {
    one,
    two,
}

enum<str> StrEnum {
    one,
    two,
    three,
}

enum<int> IntEnum {
    one = 1,
    two = 2,
    three = 3,
        // wat = "wat",
}

enum NaturalEnum {
    zero,
    one,
    two,
}

fun getValue(case: NaturalEnum = NaturalEnum.zero) > int {
    return case.value;
}

/// Return enum value with an anonymous enum case default.
fun getAnonymousDefaultValue(case: NaturalEnum = .one) > int {
    return case.value;
}

/// Object used to verify anonymous enum default values in methods.
object NaturalDefaults {
    /// Return enum value with an anonymous enum case default.
    static fun getValue(case: NaturalEnum = .two) > int {
        return case.value;
    }
}

object Natural {
    natural: NaturalEnum = NaturalEnum.zero,
}

/// Object used to verify enum inference in anonymous object fields.
object NaturalSetting {
    /// Enum field inferred from an anonymous enum case.
    natural: NaturalEnum,
}

/// Object used to verify nested anonymous object inference in maps.
object NaturalSource {
    /// Optional nested object inferred from a map value field.
    setting: NaturalSetting?,
    /// Required source URL.
    url: str,
}

test "Enums" {
    std\assert(StrEnum.one.value == "one", message: "str enum");

    std\assert(IntEnum.one.value == 1, message: "int enum");

    std\assert(NaturalEnum.zero.value == 0, message: "natural enum");

    final myCase = NaturalEnum.two;

    std\assert(myCase.value == 2, message: "enum instance");

    final fromValue = NaturalEnum(0);
    std\assert(fromValue != null, message: "Could get enum instance from value");
    std\assert(
        fromValue?.value == 0,
        message: "Could get correct enum instance from value"
    );
}

test "Enum case as default value" {
    std\assert(
        getValue() == 0,
        message: "Could use enum case as function argument default value"
    );

    std\assert(
        Natural{}.natural == NaturalEnum.zero,
        message: "Could use enum case as object field default value"
    );

    std\assert(
        getAnonymousDefaultValue() == 1,
        message: "Could use anonymous enum case as function argument default value"
    );

    std\assert(
        NaturalDefaults.getValue() == 2,
        message: "Could use anonymous enum case as method argument default value"
    );

    std\assert(
        getForwardAnonymousDefaultValue() == 0,
        message: "Could use forward anonymous enum case as function argument default value"
    );

    std\assert(
        ForwardNaturalDefaults.getValue() == 1,
        message: "Could use forward anonymous enum case as method argument default value"
    );
}

test "Anonymous enum case inference" {
    final setting: NaturalSetting = .{ natural = .two };

    std\assert(
        setting.natural == NaturalEnum.two,
        message: "Could infer anonymous enum case in object field",
    );

    final sources: {str: NaturalSource} = {
        "tty": .{
            setting = .{
                natural = .two,
            },
            url = "git:https://example.invalid/tty.git",
        },
    };

    std\assert(
        sources["tty"]?.setting?.natural == NaturalEnum.two,
        message: "Could infer nested anonymous enum case in map object field",
    );
}
