import "buzz:std";
import "buzz:gc";

enum CapturedEnum {
    one,
    two,
}

fun upvals() > fun () {
    final upvalue = 12;
    final up = "up";

    return fun () > void => std\print("{upvalue} {up}");
}

test "Upvalues" {
    upvals()();
}

fun captureEnumCase() > fun () > CapturedEnum {
    final captured = CapturedEnum.two;

    return fun () > CapturedEnum => captured;
}

test "Closed upvalues can capture enum cases through GC" {
    _ = captureEnumCase();

    gc\collect();

    std\assert(true, message: "collecting discarded closures with enum captures does not corrupt GC");
}
