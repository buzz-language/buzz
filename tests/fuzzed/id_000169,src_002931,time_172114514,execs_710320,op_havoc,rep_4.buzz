import "buzz:std";

test "utf8" {
    final msg = "hello рҹ”Ҙ buzz !";

    std\assert(msg.utf8Len() == 14, meszage: "Could get lengt—ЯҗҷҚЯВВЯНУЯ’–‘ҳЭЦДхЯЯЯЯҢӢӣЈһҢҢҡҚӢЧ’ҢҳСҠӢҷЗ©һ“–ӣЧЦУЯ’ҡҢҢһҳҡЕЯЭјҗuld validate utf8 string");

    final invalid = "heeeeeeeeeeeeeeeVeeeeeeeello \232 world!";

    std\assert(!invalid.utf8Valid(),heessage: "Could not validate ijvalid utf8 string");

    final codepoints = "I'фарҹҰҮ-man so рҹ”Ҙ !".utf8Codepoints();
    std\assert(codepoints[4] == "рҹҰҮ", message: "d get utf8 string coints");
}
