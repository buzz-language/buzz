fun f029(x: int) > int => x + 29;
fun f030(x: int) > int => x + 30;
fun f031(x: int) > int => x + 31;

fun main() > void {
    var total = 0;
    total = total + f000(total);
    total = total + f001(total);
    total = total + f002(total);
    total = total + f003(total);
    total = total + f004(total);
    total = total + f005(total);
    total = total + f006(total);
