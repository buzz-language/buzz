// Perf focus: function-heavy compilation memory.
// Exercises per-function AST/type/chunk storage, Codegen Frame allocation,
// per-instruction Chunk.locations, and the per-function empty-string constant.

fun f000(x: int) > int => x + 0;
fun f001(x: int) > int => x + 1;
fun f002(x: int) > int => x + 2;
