// Perf focus: direct bytecodes/JIT lowering for list.append, list.len, list.remove,
// and checked-vs-unchecked list subscript get/set.

fun main() > void {
    final list: mut [int] = mut [];
    var i = 0;

    while (i < 250000) {
        list.append((i * 17) % 1000003);
        i = i + 1;
    }

    var j = 0;
    var total = 0;
    final len = list.len();

    while (j < len) {
        total = (total + list[j]) % 1000003;
        list[j] = total;
        j = j + 1;
    }

    i = 0;
    while (i < 100000) {
        total = total + (list.remove(list.len() - 1) ?? 0);
        i = i + 1;
    }

    _ = total;
}
