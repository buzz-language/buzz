// Perf focus: Scanner.docblock allocation and StringParser interpolation chunk reuse.
// Compile this file to compare docblock/string-parser allocator traffic.

/// Docblock 00 intentionally has enough words to allocate a real buffer.
fun doc000(value: int) > str => "value {value} escaped newline\npart 00";

/// Docblock 01 intentionally has enough words to allocate a real buffer.
fun doc001(value: int) > str => "value {value} escaped newline\npart 01";

/// Docblock 02 intentionally has enough words to allocate a real buffer.
fun doc002(value: int) > str => "value {value} escaped newline\npart 02";

/// Docblock 03 intentionally has enough words to allocate a real buffer.
fun doc003(value: int) > str => "value {value} escaped newline\npart 03";

/// Docblock 04 intentionally has enough words to allocate a real buffer.
fun doc004(value: int) > str => "value {value} escaped newline\npart 04";

/// Docblock 05 intentionally has enough words to allocate a real buffer.
fun doc005(value: int) > str => "value {value} escaped newline\npart 05";

/// Docblock 06 intentionally has enough words to allocate a real buffer.
fun doc006(value: int) > str => "value {value} escaped newline\npart 06";

/// Docblock 07 intentionally has enough words to allocate a real buffer.
fun doc007(value: int) > str => "value {value} escaped newline\npart 07";

fun main() > void {
    final n = 42;
    _ = doc000(n) + doc001(n) + doc002(n) + doc003(n)
        + doc004(n) + doc005(n) + doc006(n) + doc007(n);
}
