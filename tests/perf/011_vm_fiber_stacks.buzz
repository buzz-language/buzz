// Perf focus: fixed 100k-Value stack allocation per fiber and GC parent-fiber marking.
// The fibers are kept alive at once so stack allocation dominates peak memory.

fun worker(n: int) > int *> int? {
    var i = 0;
    var total = 0;

    while (i < n) {
        total = total + i;
        _ = yield total;
        i = i + 1;
    }

    return total;
}

fun main() > void {
    final fibers: mut [any] = mut [];
    var i = 0;

    while (i < 64) {
        fibers.append(&worker(4));
        i = i + 1;
    }

    _ = fibers.len();
}
