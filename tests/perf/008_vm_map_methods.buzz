// Perf focus: map.size/map get/set native dispatch, map subscript specialization,
// list/map method-cache memory, and JIT direct lowering for typed map operations.

fun main() > void {
    final map: mut {int: int} = mut {};
    var i = 0;

    while (i < 120000) {
        map[i] = (i * 31) % 1000003;
        i = i + 1;
    }

    i = 0;
    var total = 0;
    while (i < 120000) {
        total = (total + (map[i] ?? 0) + map.size()) % 1000003;
        i = i + 1;
    }

    _ = total;
}
