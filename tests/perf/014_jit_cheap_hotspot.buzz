// Perf focus: JIT candidate scoring should compile cheap, arithmetic-heavy loops early.
// This shape has high expected speedup and low compile cost.

fun hot(value: int) > int {
    var i = 0;
    var total = value;

    while (i < 2000) {
        total = (total * 13 + i) % 1000003;
        i = i + 1;
    }

    return total;
}

fun main() > void {
    var i = 0;
    var total = 0;

    while (i < 2000) {
        total = total + hot(i);
        i = i + 1;
    }

    _ = total;
}
