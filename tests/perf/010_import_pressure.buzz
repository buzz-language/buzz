import "tests/perf/imports/leaf_02" as leaf02;
import "tests/perf/imports/leaf_03" as leaf03;
import "tests/perf/imports/leaf_04" as leaf04;
import "tests/perf/imports/leaf_05" as leaf05;
import "tests/perf/imports/leaf_06" as leaf06;
import "tests/perf/imports/leaf_07" as leaf07;
import "tests/perf/imports/leaf_08" as leaf08;

test "import pressure" {
