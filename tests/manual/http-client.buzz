import "buzz:http" as _;
import "buzz:debug";
import "buzz:errors";

fun main() > void !> any {
    final client = Client.init();

    final request = mut Request{
        method = .GET,
        headers = {
            "accept": "*/*",
        },
        uri = "https://google.com",
    };

    final response = client.send(request);

    debug\dump(response.body ?? "none");
}
