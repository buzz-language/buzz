import "std";

protocol Sum {
    fun sum() > int;
}

object<Sum> Payload {
    data: [int],

    static fun init() => Payload{
        data = [],
    };

    fun sum() > int {
        var sum = 0;
        foreach (item in this.data) {
            sum += item;
        }

        return sum;
    }
}

enum Lang {
    french,
    english,
    englush,
    russian,
}

fun stack2(n: int) > str {
    final local2 = 43;

    return "{n * 3}".split("").join("");
}

fun stack1(n: int) > int {
    final local = 42;

    return std\parseInt(
        stack2(n * local),
    ) ?? 0;
}

