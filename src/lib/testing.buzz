namespace testing;

import "os";
import "io";

enum<int> Color {
    // attributes
    reset = 0,
    bright = 1,
    dim = 2,
    underscore = 4,
    blink = 5,
    reverse = 7,
    hidden = 8,

        // foreground
    black = 30,
    red = 31,
    green = 32,
    yellow = 33,
    blue = 34,
    magenta = 35,
    cyan = 36,
    white = 37,

        // background
    onblack = 40,
    onred = 41,
    ongreen = 42,
    onyellow = 43,
    onblue = 44,
    onmagenta = 45,
    oncyan = 46,
    onwhite = 47,
}

fun color(text: str, color: Color, reset: bool = true) > str {
    if (os\env("OS") == "Windows_NT" or os\env("NO_COLOR") != null) {
        return text;
    }

    return "\027[{color.value}m{text}{if (reset) "\027[0m" else ""}";
}

fun bright(text: str) => color(text, color: Color.bright);

fun dim(text: str) => color(text, color: Color.dim);

fun underscore(text: str) => color(text, color: Color.underscore);

fun blink(text: str) => color(text, color: Color.blink);

fun reverse(text: str) => color(text, color: Color.reverse);

fun hidden(text: str) => color(text, color: Color.hidden);

fun black(text: str) => color(text, color: Color.black);

fun red(text: str) => color(text, color: Color.red);

fun green(text: str) => color(text, color: Color.green);

fun yellow(text: str) => color(text, color: Color.yellow);

fun blue(text: str) => color(text, color: Color.blue);

fun magenta(text: str) => color(text, color: Color.magenta);

fun cyan(text: str) => color(text, color: Color.cyan);

fun white(text: str) => color(text, color: Color.white);

fun onblack(text: str) => color(text, color: Color.onblack);

fun onred(text: str) => color(text, color: Color.onred);

fun ongreen(text: str) => color(text, color: Color.ongreen);

fun onyellow(text: str) => color(text, color: Color.onyellow);

fun onblue(text: str) => color(text, color: Color.onblue);

fun onmagenta(text: str) => color(text, color: Color.onmagenta);

fun oncyan(text: str) => color(text, color: Color.oncyan);

fun onwhite(text: str) => color(text, color: Color.onwhite);

/// Test runner with assertion helpers.
export object Tester {
    /// Test results.
    tests: mut [bool],
    /// Assertion results.
    asserts: mut [bool],
    /// Elapsed test time in milliseconds.
    elapsed: double = 0.0,
    /// Hook run once before all tests.
    beforeAll: fun (t: Tester) > void?,
    /// Hook run before each test.
    beforeEach: fun (t: Tester) > void?,
    /// Hook run once after all tests.
    afterAll: fun (t: Tester) > void?,
    /// Hook run after each test.
    afterEach: fun (t: Tester) > void?,

    /// Creates a new tester and runs the `beforeAll` hook when provided.
    /// @param beforeAll Hook run once before all tests
    /// @param beforeEach Hook run before each test
    /// @param afterAll Hook run once after all tests
    /// @param afterEach Hook run after each test
    /// @return A new `Tester`
    static fun init(
        beforeAll: fun (t: Tester) > void?,
        beforeEach: fun (t: Tester) > void?,
        afterAll: fun (t: Tester) > void?,
        afterEach: fun (t: Tester) > void?
    ) > mut Tester {
        final t = mut Tester{
            tests = mut [],
            asserts = mut [],
            beforeAll = beforeAll,
            beforeEach = beforeEach,
            afterAll = afterAll,
            afterEach = afterEach,
        };

        if (t.beforeAll -> before) {
            before(t);
        }

        return t;
    }

    /// Clears test results and elapsed time.
    mut fun reset() > void {
        this.tests = mut [];
        this.asserts = mut [];
        this.elapsed = 0.0;
    }

    /// @return number of failed assertions
    fun failedAsserts() => this.asserts.reduce::<int>(
        fun (_: int, success: bool, accumulator: int) => accumulator
            + if (success) 0 else 1,
        initial: 0,
    );

    /// @return number of failed tests
    fun failedTests() => this.tests.reduce::<int>(
        fun (_: int, success: bool, accumulator: int) => accumulator
            + if (success) 0 else 1,
        initial: 0,
    );

    /// @return number of succeeded tests
    fun succeededTests() => this.tests.reduce::<int>(
        fun (_: int, success: bool, accumulator: int) => accumulator
            + if (success) 1 else 0,
        initial: 0,
    );

    /// Runs a test case.
    /// @param message Test description
    /// @param fn Test body
    mut fun it(message: str, fn: fun () > void) > void {
        final startTime = os\time();

        io\stdout.write(
            yellow(
                "{if (os\env("OS") == "Windows_NT") ">" else "\226\150\182"} Test: {message}\n"
            )
        ) catch void;

        if (this.beforeEach -> beforeEach) {
            beforeEach(this);
        }

        final previousFailCount = this.failedAsserts();
        fn();

        if (this.afterEach -> afterEach) {
            afterEach(this);
        }

        this.tests.append(previousFailCount == this.failedAsserts());

        this.elapsed = this.elapsed + (os\time() - startTime);
    }

    /// Prints a test summary and exits with a failure code when any test failed.
    fun summary() > void {
        if (this.afterAll -> afterAll) {
            afterAll(this);
        }

        final failed = this.failedTests();

        io\stdout.write("\n") catch void;

        foreach (testStatus in this.tests) {
            if (testStatus) {
                io\stdout.write(
                    green(if (os\env("OS") == "Windows_NT") "." else "\226\151\143")
                ) catch void;
            } else {
                io\stdout.write(
                    yellow(if (os\env("OS") == "Windows_NT") "x" else "\226\151\143")
                ) catch void;
            }
        }

        io\stdout.write(
            green("\n{this.succeededTests()}") + dim(" successes, ") + yellow(
                "{failed}"
            ) + dim(" failures in ") + "{this.elapsed / 1000.0}" + dim(
                " seconds\n"
            )
        ) catch void;

        if (failed > 0) {
            os\exit(1);
        }
    }

    /// Reports an assertion failure.
    /// @param error Error details
    /// @param message Assertion message
    fun report(error: str?, message: str?) > void {
        io\stderr.write(
            red("  Assert failed: {message ?? ""}") + dim("\n    {error}\n")
        ) catch void;
    }

    /// Records whether an assertion condition succeeded.
    /// @param condition Condition that must be true
    /// @param error Error details printed when false
    /// @param message Assertion message
    fun assert(condition: bool, error: str?, message: str?) > void {
        if (!condition) {
            this.report(error, message: message);

            this.asserts.append(false);
        } else {
            this.asserts.append(true);
        }
    }

    /// Asserts that two values are equal.
    /// @param actual Actual value
    /// @param expected Expected value
    /// @param message Assertion message
    fun assertEqual(actual: any, expected: any, message: str?) > void {
        this.assert(
            actual == expected,
            error: "expected `{expected}` got `{actual}`",
            message: message
        );
    }

    /// Asserts that two values are not equal.
    /// @param actual Actual value
    /// @param expected Value that should differ
    /// @param message Assertion message
    fun assertNotEqual(actual: any, expected: any, message: str?) > void {
        this.assert(
            actual != expected,
            error: "expected `{expected}` got `{actual}`",
            message: message
        );
    }

    /// Asserts that all values are equal.
    /// @param values Values to compare
    /// @param message Assertion message
    fun assertAreEqual(values: [any], message: str?) > void {
        if (values.len() < 2) {
            return;
        }

        var equal = true;
        var previous = values[0];
        foreach (value in values) {
            if (value != previous) {
                equal = false;
                break;
            }

            previous = value;
        }

        this.assert(equal, error: "one element is not equal", message: message);
    }

    /// Asserts that adjacent values are not equal.
    /// @param values Values to compare
    /// @param message Assertion message
    fun assertAreNotEqual(values: [any], message: str?) > void {
        if (values.len() < 2) {
            return;
        }

        var equal = true;
        var previous = values[0];
        foreach (i, value in values) {
            if (i > 0 and value == previous) {
                equal = false;
                break;
            }

            previous = value;
        }

        this.assert(equal, error: "one element is equal", message: message);
    }

    /// Asserts that a value has type `T`.
    /// @param value Value to check
    /// @param message Assertion message
    fun assertOfType::<T>(value: any, message: str?) > void {
        this.assert(
            !(value is T),
            error: "`{value}` type is `{typeof value}`",
            message: message
        );
    }

    /// Asserts that a function throws an error of type `T`.
    /// @param fn Function expected to throw
    /// @param message Assertion message
    fun assertThrows::<T>(fn: fun () > void !>
        T, message: str?) > void {
        try {
            fn();
        } catch (error: any) {
            this.assertOfType::<T>(error, message: message);
            return;
        }

        this.assert(false, error: "Did not throw", message: message);
    }

    /// Asserts that a function does not throw an error of type `T`.
    /// @param fn Function expected not to throw
    /// @param message Assertion message
    fun assertDoesNotThrow::<T>(fn: fun () > void, message: str?) > void {
        try {
            fn();
        } catch (error: any) {
            if (error is T) {
                this.assert(false, error: "Did throw", message: message);
                return;
            }
        }
    }
}
